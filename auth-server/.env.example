# Server Configuration
PORT=3000
NODE_ENV=production

# Authentication - TOTP (Authenticator App)
# Leave TOTP_SECRET empty on first run to generate one
TOTP_SECRET=
APP_NAME=ServerIndex

# JWT Configuration
JWT_SECRET=roxy_migurdia_is_the_goat
SESSION_TIMEOUT=3600000

# Admin Debug Credentials (optional)
ADMIN_USER=admin
ADMIN_PASS=skibiditoilet

# Spotify API (required for /api/music/random-albums)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Discord Suggestions (optional)
# Use either DISCORD_SUGGESTIONS_WEBHOOK_URL or BOT_TOKEN + CHANNEL_ID in your deploy env
DISCORD_SUGGESTIONS_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_SUGGESTIONS_CHANNEL_ID=

# Mention control: only this user will be pinged in suggestion/status posts
# Set your Discord user ID (not username), e.g. 123456789012345678
DISCORD_MENTION_USER_ID=
